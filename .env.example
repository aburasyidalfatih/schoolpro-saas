# Database — PostgreSQL (start with: docker compose up db -d)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="ganti-dengan-password-kuat-di-production"
POSTGRES_DB="saasmasterpro"

# URL untuk lokal (tanpa docker): "postgresql://postgres:password@localhost:5432/saasmasterpro"
# URL untuk Docker Compose (production): "postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}"

# Auth.js v5
AUTH_URL="http://localhost:3000"
AUTH_SECRET="ganti-dengan-secret-random-yang-panjang"

# Google OAuth (opsional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Domain (untuk multi-tenant subdomain)
# Contoh lokal: schoolpro.test
# Contoh VPS: schoolpro.id
NEXT_PUBLIC_ROOT_DOMAIN="schoolpro.test"
NEXT_PUBLIC_APP_URL="http://schoolpro.test"

# Upstash Redis (untuk rate limiting & domain cache — production)
# Pilihan 1: Upstash Cloud (gratis di https://upstash.com)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Pilihan 2: Redis lokal/VPS (redis://localhost:6379 atau redis://:password@host:6379)
REDIS_URL="redis://redis:6379"

# Tripay Payment Gateway
TRIPAY_API_KEY=""
TRIPAY_PRIVATE_KEY=""
TRIPAY_MERCHANT_CODE=""
TRIPAY_API_URL="https://tripay.co.id/api-sandbox"

# StarSender WhatsApp Gateway
STARSENDER_API_KEY=""
STARSENDER_API_URL="https://api.starsender.online/api"

# Mailketing SMTP
SMTP_HOST="smtp.mailketing.co.id"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@saasmasterpro.com"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="5242880"

# Internal API Secret (untuk komunikasi antar service internal, generate random string)
INTERNAL_API_SECRET="ganti-dengan-random-string-panjang"
