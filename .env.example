# Database
DATABASE_URL="file:./dev.db"
# Untuk production PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/saasmasterpro"

# Auth.js v5
AUTH_URL="http://localhost:3000"
AUTH_SECRET="ganti-dengan-secret-random-yang-panjang"

# Google OAuth (opsional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Domain (untuk multi-tenant subdomain)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upstash Redis (untuk rate limiting production)
# Buat gratis di https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Tripay Payment Gateway
TRIPAY_API_KEY=""
TRIPAY_PRIVATE_KEY=""
TRIPAY_MERCHANT_CODE=""
TRIPAY_API_URL="https://tripay.co.id/api-sandbox"

# StarSender WhatsApp Gateway
STARSENDER_API_KEY=""
STARSENDER_API_URL="https://api.starsender.online/api"

# Mailketing SMTP
SMTP_HOST="smtp.mailketing.co.id"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@saasmasterpro.com"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="5242880"
