generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & AUTH ====================

model Tenant {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  domain      String? @unique
  logo        String?
  description String?
  plan        String  @default("free")
  theme       String  @default("aurora")
  isActive    Boolean @default(true)
  settings    Json? // Tenant-specific settings (SMTP, payment, WA gateway)

  // Website company profile fields
  tagline   String?
  about     String? @db.Text // Rich text / markdown
  address   String?
  phone     String?
  email     String?
  website   String?
  whatsapp  String?
  instagram String?
  facebook  String?
  youtube   String?
  services  Json? // JSON array of {title, description, icon, order}
  heroImage String?
  gallery   Json? // JSON array of {url, caption, order}
  seoTitle  String? // Custom SEO title
  seoDesc   String? // Custom SEO description (max 160 chars)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              TenantUser[]
  invitations        Invitation[]
  notifications      Notification[]
  payments           Payment[]
  auditLogs          AuditLog[]
  contactSubmissions ContactSubmission[]

  // CMS Website Relations
  posts            Post[]
  documents        Document[]
  events           Event[]
  achievements     Achievement[]
  facilities       Facility[]
  extracurriculars Extracurricular[]
  programs         Program[]
  alumni           Alumni[]

  @@index([isActive])
  @@index([plan])
  @@map("tenants")
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  password             String
  phone                String?
  avatar               String?
  emailVerified        DateTime?
  isActive             Boolean   @default(true)
  isSuperAdmin         Boolean   @default(false)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json? // JSON array of hashed backup codes
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenants              TenantUser[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  auditLogs            AuditLog[]
  sessions             Session[]
  verificationTokens   VerificationToken[]

  // CMS Relations
  posts          Post[]
  documents      Document[]
  alumniProfiles Alumni[]

  @@index([isActive])
  @@index([isSuperAdmin])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  deviceName   String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  role     String @default("member") // owner, admin, teacher, operator, member

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

model Invitation {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("invitations")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String // email_verify, password_reset
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info") // info, success, warning, error
  channel   String   @default("inapp") // inapp, email, whatsapp
  isRead    Boolean  @default(false)
  metadata  Json? // Additional notification metadata
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationSetting {
  id      String  @id @default(cuid())
  userId  String
  channel String // inapp, email, whatsapp
  enabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_settings")
}

// ==================== PAYMENTS ====================

model Payment {
  id        String    @id @default(cuid())
  tenantId  String
  reference String    @unique
  amount    Float
  method    String?
  status    String    @default("pending") // pending, paid, failed, expired
  plan      String
  tripayRef String?
  paidAt    DateTime?
  expiredAt DateTime?
  metadata  Json? // Additional payment metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json? // Previous state snapshot
  newData   Json? // New state snapshot
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== FILE UPLOADS ====================

model FileUpload {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("file_uploads")
}

// ==================== CONTACT SUBMISSIONS ====================

model ContactSubmission {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isRead])
  @@index([createdAt])
  @@map("contact_submissions")
}

// ==================== PLATFORM SETTINGS ====================

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("platform_settings")
}

// ==================== CMS & WEBSITE FEATURES ====================

model Post {
  id            String   @id @default(cuid())
  tenantId      String
  authorId      String
  title         String
  slug          String
  content       String   @db.Text
  featuredImage String?
  type          String   @default("BLOG_GURU") // EDITORIAL, BLOG_GURU, PENGUMUMAN
  status        String   @default("PUBLISHED") // DRAFT, PUBLISHED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([authorId])
  @@index([type])
  @@index([status])
  @@map("posts")
}

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  uploaderId  String
  title       String
  description String?  @db.Text
  fileUrl     String
  mimeType    String
  size        Int
  type        String   @default("MATERI_TUGAS") // MATERI_TUGAS, UNDUHAN_UMUM
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([uploaderId])
  @@index([type])
  @@map("documents")
}

model Event {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  description   String?  @db.Text
  location      String?
  contactPerson String?
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([startDate])
  @@map("events")
}

model Achievement {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?  @db.Text
  date        DateTime
  level       String   @default("LOKAL") // LOKAL, NASIONAL, INTERNASIONAL
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("achievements")
}

model Facility {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?  @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("facilities")
}

model Extracurricular {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?  @db.Text
  schedule    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("extracurriculars")
}

model Program {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?  @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("programs")
}

model Alumni {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  name            String
  graduationYear  Int
  currentStatus   String   @default("KULIAH") // BEKERJA, KULIAH, WIRAUSAHA
  institutionName String?
  testimonial     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@map("alumni")
}
