generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  domain             String?             @unique
  logo               String?
  description        String?
  plan               String              @default("free")
  theme              String              @default("aurora")
  isActive           Boolean             @default(true)
  settings           Json?
  tagline            String?
  about              String?
  address            String?
  phone              String?
  email              String?
  website            String?
  whatsapp           String?
  instagram          String?
  facebook           String?
  youtube            String?
  services           Json?
  heroImage          String?
  gallery            Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  expiresAt          DateTime?
  planId             String?
  seoDesc            String?
  seoTitle           String?
  studentQuota       Int                 @default(0)
  achievements       Achievement[]
  alumni             Alumni[]
  auditLogs          AuditLog[]
  categories         Category[]
  contactSubmissions ContactSubmission[]
  documents          Document[]
  events             Event[]
  extracurriculars   Extracurricular[]
  facilities         Facility[]
  invitations        Invitation[]
  notifications      Notification[]
  payments           Payment[]
  popups             Popup[]
  posts              Post[]
  programs           Program[]
  sliders            Slider[]
  staff              Staff[]
  subscriptions      Subscription[]
  users              TenantUser[]
  periodePpdb        PeriodePpdb[]
  pendaftarPpdb      PendaftarPpdb[]
  rekening           Rekening[]
  students           Student[]
  subscriptionPlan   SubscriptionPlan?   @relation(fields: [planId], references: [id])

  @@index([isActive])
  @@index([plan])
  @@index([planId])
  @@map("tenants")
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  password             String
  phone                String?
  avatar               String?
  emailVerified        DateTime?
  isActive             Boolean               @default(true)
  isSuperAdmin         Boolean               @default(false)
  twoFactorEnabled     Boolean               @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  alumniProfiles       Alumni[]
  auditLogs            AuditLog[]
  documents            Document[]
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  posts                Post[]
  sessions             Session[]
  staffProfiles        Staff[]
  pendaftarPpdb        PendaftarPpdb[]
  students             Student[]
  tenants              TenantUser[]
  verificationTokens   VerificationToken[]

  @@index([isActive])
  @@index([isSuperAdmin])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  deviceName   String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  role     String @default("member")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

model Invitation {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("invitations")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  title     String
  message   String
  type      String   @default("info")
  channel   String   @default("inapp")
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationSetting {
  id      String  @id @default(cuid())
  userId  String
  channel String
  enabled Boolean @default(true)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_settings")
}

model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  reference    String        @unique
  amount       Float
  method       String?
  status       String        @default("pending")
  plan         String
  tripayRef    String?
  paidAt       DateTime?
  expiredAt    DateTime?
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  planId       String?
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription?

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model FileUpload {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("file_uploads")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isRead])
  @@index([createdAt])
  @@map("contact_submissions")
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("platform_settings")
}

model TenantApplication {
  id           String   @id @default(cuid())
  schoolName   String
  schoolSlug   String   @unique
  adminName    String
  adminEmail   String
  adminPhone   String
  address      String?
  status       String   @default("PENDING")
  adminMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  npsn         String?
  province     String?
  regency      String?
  schoolStatus String?  @default("SWASTA")
  logo         String?

  @@index([status])
  @@map("tenant_applications")
}

model Post {
  id            String    @id @default(cuid())
  tenantId      String
  authorId      String
  title         String
  slug          String
  content       String
  featuredImage String?
  type          String    @default("BLOG_GURU")
  status        String    @default("PUBLISHED")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  seoDesc       String?
  seoTitle      String?
  categoryId    String?
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      Category? @relation(fields: [categoryId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([authorId])
  @@index([categoryId])
  @@index([type])
  @@index([status])
  @@map("posts")
}

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts       Post[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  uploaderId  String
  title       String
  description String?
  fileUrl     String
  mimeType    String
  size        Int
  type        String   @default("MATERI_TUGAS")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([uploaderId])
  @@index([type])
  @@map("documents")
}

model Event {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  description   String?
  location      String?
  contactPerson String?
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([startDate])
  @@map("events")
}

model Achievement {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  date        DateTime
  level       String   @default("LOKAL")
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("achievements")
}

model Facility {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("facilities")
}

model Extracurricular {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  schedule    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("extracurriculars")
}

model Program {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("programs")
}

model Alumni {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  name            String
  graduationYear  Int
  currentStatus   String   @default("KULIAH")
  institutionName String?
  testimonial     String?
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("alumni")
}

model Staff {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  role      String
  imageUrl  String?
  bio       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String?
  userId    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("staff")
}

model Popup {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  content     String?
  imageUrl    String?
  videoUrl    String?
  buttonText  String?
  buttonLink  String?
  isActive    Boolean  @default(false)
  displayOnce Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("popups")
}

model Slider {
  id         String   @id @default(cuid())
  tenantId   String
  title      String?
  subtitle   String?
  imageUrl   String
  buttonText String?
  buttonLink String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("sliders")
}

model SubscriptionPlan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Float          @default(0)
  interval      String         @default("MONTHLY")
  features      Json?
  maxStudents   Int            @default(0)
  maxStorage    Int            @default(0)
  isActive      Boolean        @default(true)
  isPopular     Boolean        @default(false)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  tenants       Tenant[]

  @@map("subscription_plans")
}

model Subscription {
  id        String           @id @default(cuid())
  tenantId  String
  planId    String
  paymentId String?          @unique
  status    String           @default("ACTIVE")
  startDate DateTime         @default(now())
  endDate   DateTime?
  amount    Float            @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  payment   Payment?         @relation(fields: [paymentId], references: [id])
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model PeriodePpdb {
  id           String              @id @default(cuid())
  tenantId     String
  nama         String
  tanggalBuka  DateTime
  tanggalTutup DateTime
  isActive     Boolean             @default(true)
  pengaturan   Json?               // biayaPendaftaran, kuota, biayaDaftarUlang
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pendaftar    PendaftarPpdb[]
  persyaratan  PersyaratanBerkas[]

  @@index([tenantId])
  @@index([isActive])
  @@map("periode_ppdbs")
}

model PersyaratanBerkas {
  id        String       @id @default(cuid())
  periodeId String
  nama      String
  isWajib   Boolean      @default(true)
  tipeFile  String?      // e.g., "image/*,application/pdf"
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  periode   PeriodePpdb  @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  berkas    BerkasPpdb[]

  @@index([periodeId])
  @@map("persyaratan_berkas")
}

model PendaftarPpdb {
  id             String        @id @default(cuid())
  tenantId       String
  userId         String
  periodeId      String
  noPendaftaran  String        @unique
  namaLengkap    String
  dataFormulir   Json?         // NISN, jenis kelamin, TTL, alamat, telepon
  dataOrangtua   Json?         // ayah, ibu, wali
  status         String        @default("MENUNGGU") // MENUNGGU, TERVERIFIKASI, DITERIMA, DITOLAK
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  periode        PeriodePpdb   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  berkas         BerkasPpdb[]
  tagihan        TagihanPpdb[]

  @@index([tenantId])
  @@index([userId])
  @@index([periodeId])
  @@index([status])
  @@map("pendaftar_ppdbs")
}

model BerkasPpdb {
  id            String            @id @default(cuid())
  pendaftarId   String
  requirementId String
  fileUrl       String
  status        String            @default("MENUNGGU") // MENUNGGU, DITERIMA, DITOLAK
  catatan       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  pendaftar     PendaftarPpdb     @relation(fields: [pendaftarId], references: [id], onDelete: Cascade)
  requirement   PersyaratanBerkas @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([pendaftarId])
  @@index([requirementId])
  @@map("berkas_ppdbs")
}

model TagihanPpdb {
  id          String           @id @default(cuid())
  pendaftarId String
  jenis       String           // PENDAFTARAN, DAFTAR_ULANG
  nominal     Float
  items       Json?            // breakdown: [{nama: "Seragam", nominal: 500000}, ...]
  status      String           @default("BELUM_LUNAS") // BELUM_LUNAS, LUNAS
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  pendaftar   PendaftarPpdb    @relation(fields: [pendaftarId], references: [id], onDelete: Cascade)
  pembayaran  PembayaranPpdb[]

  @@index([pendaftarId])
  @@map("tagihan_ppdbs")
}

model PembayaranPpdb {
  id          String      @id @default(cuid())
  tagihanId   String
  nominal     Float
  buktiUrl    String?
  status      String      @default("PENDING") // PENDING, APPROVED, REJECTED
  catatan     String?
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tagihan     TagihanPpdb @relation(fields: [tagihanId], references: [id], onDelete: Cascade)

  @@index([tagihanId])
  @@map("pembayaran_ppdbs")
}

model Rekening {
  id            String   @id @default(cuid())
  tenantId      String
  namaBank      String
  nomorRekening String
  atasNama      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("rekenings")
}

model Student {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String?
  noPendaftaran  String?   // optional link to PPDB
  nis            String?   @unique
  nisn           String?   @unique
  name           String
  gender         String?
  birthPlace     String?
  birthDate      DateTime?
  address        String?
  phone          String?
  email          String?
  fatherName     String?
  motherName     String?
  guardianName   String?
  metadata       Json?
  isActive       Boolean   @default(true)
  syncedAt       DateTime? // when it was synced from PPDB
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([isActive])
  @@map("students")
}
