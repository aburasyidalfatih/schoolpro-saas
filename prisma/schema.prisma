generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  domain             String?             @unique
  logo               String?
  description        String?
  plan               String              @default("free")
  theme              String              @default("aurora")
  isActive           Boolean             @default(true)
  settings           Json?
  tagline            String?
  about              String?
  address            String?
  phone              String?
  email              String?
  website            String?
  whatsapp           String?
  instagram          String?
  facebook           String?
  youtube            String?
  services           Json?
  heroImage          String?
  gallery            Json?
  seoTitle           String?
  seoDesc            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  expiresAt          DateTime?
  studentQuota       Int                 @default(0)
  achievements       Achievement[]
  alumni             Alumni[]
  auditLogs          AuditLog[]
  contactSubmissions ContactSubmission[]
  documents          Document[]
  events             Event[]
  extracurriculars   Extracurricular[]
  facilities         Facility[]
  invitations        Invitation[]
  notifications      Notification[]
  payments           Payment[]
  posts              Post[]
  popups             Popup[]
  sliders            Slider[]
  programs           Program[]
  staff              Staff[]
  users              TenantUser[]

  @@index([isActive])
  @@index([plan])
  @@map("tenants")
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  password             String
  phone                String?
  avatar               String?
  emailVerified        DateTime?
  isActive             Boolean               @default(true)
  isSuperAdmin         Boolean               @default(false)
  twoFactorEnabled     Boolean               @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  alumniProfiles       Alumni[]
  auditLogs            AuditLog[]
  documents            Document[]
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  posts                Post[]
  sessions             Session[]
  tenants              TenantUser[]
  verificationTokens   VerificationToken[]

  @@index([isActive])
  @@index([isSuperAdmin])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  deviceName   String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  role     String @default("member")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

model Invitation {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("invitations")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  title     String
  message   String
  type      String   @default("info")
  channel   String   @default("inapp")
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationSetting {
  id      String  @id @default(cuid())
  userId  String
  channel String
  enabled Boolean @default(true)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_settings")
}

model Payment {
  id        String    @id @default(cuid())
  tenantId  String
  reference String    @unique
  amount    Float
  method    String?
  status    String    @default("pending")
  plan      String
  tripayRef String?
  paidAt    DateTime?
  expiredAt DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model FileUpload {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("file_uploads")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isRead])
  @@index([createdAt])
  @@map("contact_submissions")
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("platform_settings")
}

model TenantApplication {
  id           String   @id @default(cuid())
  schoolName   String
  schoolSlug   String   @unique
  adminName    String
  adminEmail   String
  adminPhone   String
  address      String?
  status       String   @default("PENDING")
  adminMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  npsn         String?
  province     String?
  regency      String?
  schoolStatus String?  @default("SWASTA")

  @@index([status])
  @@map("tenant_applications")
}

model Post {
  id            String   @id @default(cuid())
  tenantId      String
  authorId      String
  title         String
  slug          String
  content       String
  featuredImage String?
  type          String   @default("BLOG_GURU")
  status        String   @default("PUBLISHED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([authorId])
  @@index([type])
  @@index([status])
  @@map("posts")
}

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  uploaderId  String
  title       String
  description String?
  fileUrl     String
  mimeType    String
  size        Int
  type        String   @default("MATERI_TUGAS")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([uploaderId])
  @@index([type])
  @@map("documents")
}

model Event {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  description   String?
  location      String?
  contactPerson String?
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([startDate])
  @@map("events")
}

model Achievement {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  date        DateTime
  level       String   @default("LOKAL")
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("achievements")
}

model Facility {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("facilities")
}

model Extracurricular {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  schedule    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("extracurriculars")
}

model Program {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("programs")
}

model Alumni {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  name            String
  graduationYear  Int
  currentStatus   String   @default("KULIAH")
  institutionName String?
  testimonial     String?
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("alumni")
}

model Staff {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  role        String   // Jabatan (Guru, Kepala Sekolah, etc)
  imageUrl    String?
  bio         String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("staff")
}

model Popup {
  id          String    @id @default(cuid())
  tenantId    String
  title       String
  content     String?   @db.Text
  imageUrl    String?
  videoUrl    String?   // YouTube/Vimeo link
  buttonText  String?
  buttonLink  String?
  isActive    Boolean   @default(false)
  displayOnce Boolean   @default(true) // Per user session
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("popups")
}

model Slider {
  id          String    @id @default(cuid())
  tenantId    String
  title       String?
  subtitle    String?
  imageUrl    String
  buttonText  String?
  buttonLink  String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("sliders")
}
